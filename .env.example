R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL_BASE=

WEBFLOW_API_KEY=
WEBFLOW_COLLECTION_ID=

NEON_DATABASE_URL=

ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
ASSEMBLYAI_API_KEY=

# Memberstack 2.0 Admin API secret key (Dashboard → Dev Tools → Keys & IDs).
# Server-side only — never expose. sk_… = live, sk_sb_… = test (test capped at 50 members).
MEMBERSTACK_SECRET_KEY=
# Optional: your Memberstack app id (app_…). When set, member JWTs are verified
# with an audience check for extra hardening. Safe to leave blank.
NEXT_PUBLIC_MEMBERSTACK_APP_ID=
# Memberstack public/DOM key (pk_… live, pk_sb_… test) — Dashboard → Dev Tools → Keys.
# Used in the browser to auto-send the "set your password" email when Lindsay creates a
# client. Distinct from the app id above. NEXT_PUBLIC_ → baked in at build time. Public
# by design; leave blank to disable the auto-email step.
NEXT_PUBLIC_MEMBERSTACK_PUBLIC_KEY=
# The FREE Memberstack plan id (pln_…) attached to every new client — the "individual"
# plan. Dashboard → Plans → the plan → copy its id. Only free plans (pln_) attach on
# create. Leave blank to attach no plan.
MEMBERSTACK_INDIVIDUAL_PLAN_ID=

UPLOAD_TOOL_PASSWORD=
SESSION_SECRET=
NEXT_PUBLIC_APP_URL=

# Set to "true" once the app is served over HTTPS (real domain). Leave unset/false
# when testing over the bare droplet IP on plain HTTP, or the login cookie is dropped.
COOKIE_SECURE=

# Global booking link Lindsay reuses for everyone. Shown as a "copy booking link"
# button on the client view. NEXT_PUBLIC_ → baked in at build time (rebuild to change).
NEXT_PUBLIC_BOOKING_URL=
